# Environment variables for AQI Forecasting System
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Set USE_SQLITE=true for demo/development (no PostgreSQL needed)
USE_SQLITE=true
SQLITE_URL=sqlite+aiosqlite:///./aqi_demo.db

# For production with PostgreSQL + PostGIS:
# USE_SQLITE=false
# DATABASE_URL=postgresql+asyncpg://aqi_user:aqi_pass@localhost:5432/aqi_db

# ── ML Model ─────────────────────────────────────────────────────────────────
ACTIVE_MODEL=ensemble
# Options: xgboost, lightgbm, lstm, gru, stgnn, ensemble

# ── City Config ───────────────────────────────────────────────────────────────
CITY_NAME=Delhi
GRID_ROWS=20
GRID_COLS=20
CITY_LAT_MIN=28.40
CITY_LAT_MAX=28.88
CITY_LON_MIN=76.84
CITY_LON_MAX=77.35

# ── Training ─────────────────────────────────────────────────────────────────
NUM_EPOCHS=50
BATCH_SIZE=32
LEARNING_RATE=0.001
RANDOM_SEED=42
